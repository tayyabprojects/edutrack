rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Auxiliary Global helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function isSignedIn() { 
      return request.auth != null; 
    }
    function isOwner(schoolId) {
      return isSignedIn() && request.auth.uid == schoolId;
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tayyab@adminedutrack.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // 2. Schools Collection Rules
    match /schools/{schoolId} {
      allow read, write: if isOwner(schoolId) || isAdmin();

      // Recursive rules for all sub-collections to lock down by school ID owner
      match /{allSubDocuments=**} {
        allow read, write: if isOwner(schoolId) || isAdmin();
      }
    }

    // 3. Complaints Rules
    match /complaints/{complaintId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.schoolId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }
  }
}
